{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment_": "Personal/temporary overrides — gitignored. Copy this file to .claude/settings.local.json and adjust.",
  "permissions": {
    "allow": [
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)"
    ]
  },
  "env": {
    "TASKFLOW_LOG": "debug",
    "TASKFLOW_HOOK_DEBUG": "1"
  }
}
