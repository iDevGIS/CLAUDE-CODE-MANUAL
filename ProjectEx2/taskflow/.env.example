# TaskFlow environment variables
# Copy to `.env` (gitignored) and adjust.

# Where to persist tasks (default: .taskflow.json in cwd)
TASKFLOW_DB=.taskflow.json

# HTTP server port (default: 3000)
TASKFLOW_PORT=3000

# Log level: silent | info | debug
TASKFLOW_LOG=info

# --- Claude Code-related (consumed by hooks/scripts) ---

# When set, scripts/headless-review.sh will use this as the model
CLAUDE_MODEL=claude-sonnet-4-6

# Set to "1" to enable extra hook logging in .claude/hooks/*
TASKFLOW_HOOK_DEBUG=0
